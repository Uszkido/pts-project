generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  role        String   @default("VENDOR") // ADMIN, VENDOR, CONSUMER, POLICE, INSURANCE, TELECOM
  status      String   @default("ACTIVE") // ACTIVE, SUSPENDED
  fullName    String?
  nationalId  String?
  companyName String?
  facialDataUrl String?
  biodataUrl    String?
  cacCertificateUrl String?
  businessAddress   String?
  shopLatitude      Float?
  shopLongitude     Float?
  shopPhotoUrl      String?
  businessRegNo     String?
  vendorStatus      String   @default("PENDING") // PENDING, APPROVED, REJECTED, SUSPENDED
  vendorTier  Int      @default(3) // 1: Verified, 2: Certified, 3: Informal, 4: Watchlist
  devices     Device[]
  certificates Certificate[]
  sales        OwnershipTransfer[] @relation("Sales")
  purchases    OwnershipTransfer[] @relation("Purchases")
  trustScore   VendorTrustScore?
  incidentsReported IncidentReport[]
  vendorAlertsSubmitted VendorSuspiciousAlert[] @relation("VendorAlerts")
  actionsPerformed TransactionHistory[] @relation("ActionsPerformed")
  proofsOfSaleAsVendor ProofOfSale[] @relation("VendorSales")
  proofsOfSaleAsBuyer  ProofOfSale[] @relation("BuyerPurchases")
  sentMessages Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  maintenanceRecords MaintenanceRecord[] @relation("MaintenanceVendor")
  createdAt   DateTime @default(now())
  phoneNumber String?
  address     String?
  isEmailConfirmed Boolean @default(false)
  emailVerificationOtp String?
  passwordResetRequests PasswordResetRequest[]
}

model PasswordResetRequest {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  newPasswordHash String
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  otp             String?
  adminNotes      String?
  createdAt       DateTime @default(now())
}

model Device {
  id               String   @id @default(uuid())
  imei             String   @unique
  serialNumber     String?
  brand            String
  model            String
  status           String   @default("CLEAN") // CLEAN, STOLEN, LOST, INVESTIGATING, VENDOR_HELD, ARCHIVED, RECOVERED
  riskScore        Int      @default(100)
  lastKnownLocation String?
  lastKnownIp      String?
  lastLocationUpdate DateTime?
  registeredOwnerId String
  registeredOwner  User     @relation(fields: [registeredOwnerId], references: [id])
  certificates     Certificate[]
  transfersAsDevice OwnershipTransfer[]
  incidents        IncidentReport[]
  vendorAlerts     VendorSuspiciousAlert[]
  history          TransactionHistory[]
  proofsOfSale     ProofOfSale[]
  devicePhotos     String[]
  purchaseReceiptUrl String?
  cartonPhotoUrl   String?
  isLocationShared Boolean  @default(false)
  maintenance      MaintenanceRecord[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model VendorTrustScore {
  id          String   @id @default(uuid())
  vendorId    String   @unique
  vendor      User     @relation(fields: [vendorId], references: [id])
  score       Int      @default(100)
  completedSales Int   @default(0)
  flaggedDevices Int   @default(0)
  updatedAt   DateTime @updatedAt
}

model TelecomSyncLog {
  id          String   @id @default(uuid())
  telecomName String
  syncedAt    DateTime @default(now())
  recordsSent Int
}

model IncidentReport {
  id          String   @id @default(uuid())
  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])
  type        String   // LOST, STOLEN, SNATCHED, FRAUD
  incidentDate DateTime?
  location    String?
  description String?
  policeReportNo String?
  evidenceUrls String[]
  status      String   @default("OPEN") // OPEN, REVIEWING, RESOLVED
  locationSharedWithOwner Boolean @default(false)
  suspectId   String?
  suspect     Suspect? @relation(fields: [suspectId], references: [id])
  createdAt   DateTime @default(now())
}

model VendorSuspiciousAlert {
  id          String   @id @default(uuid())
  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  vendorId    String
  vendor      User     @relation("VendorAlerts", fields: [vendorId], references: [id])
  sellerEmail String?
  description String?
  createdAt   DateTime @default(now())
}

model Certificate {
  id          String   @id @default(uuid())
  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  issueDate   DateTime @default(now())
  qrHash      String   @unique
  isActive    Boolean  @default(true)
}

model OwnershipTransfer {
  id          String   @id @default(uuid())
  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  sellerId    String
  seller      User     @relation("Sales", fields: [sellerId], references: [id])
  buyerId     String
  buyer       User     @relation("Purchases", fields: [buyerId], references: [id])
  handoverCode String?  // The 2FA Handover Code (OTP)
  expiresAt   DateTime?
  status      String   @default("PENDING") // PENDING, COMPLETED, CANCELLED
  transferDate DateTime @default(now())
}

model TransactionHistory {
  id          String   @id @default(uuid())
  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  actorId     String?
  actor       User?    @relation("ActionsPerformed", fields: [actorId], references: [id])
  type        String   // REGISTRATION, TRANSFER, STATUS_CHANGE, CERT_ISSUANCE, SALE, RECOVERY
  description String
  metadata    String?  // JSON string
  createdAt   DateTime @default(now())
}

model ProofOfSale {
  id          String   @id @default(uuid())
  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  vendorId    String
  vendor      User     @relation("VendorSales", fields: [vendorId], references: [id])
  buyerId     String?
  buyer       User?    @relation("BuyerPurchases", fields: [buyerId], references: [id])
  transactionRef String?
  signedByVendor Boolean @default(false)
  signedByBuyer  Boolean @default(false)
  createdAt   DateTime @default(now())
}

model Suspect {
  id            String   @id @default(uuid())
  fullName      String?
  alias         String?
  nationalId    String?
  phoneNumber   String?
  description   String?
  photoUrl      String?
  knownAddresses String?
  dangerLevel   String   @default("UNKNOWN") // LOW, MEDIUM, HIGH, EXTREME, UNKNOWN
  status        String   @default("ACTIVE") // ACTIVE, CLEARED, GUILTY, NOT_GUILTY
  incidents     IncidentReport[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DeviceTrackingLog {
  id          String   @id @default(uuid())
  deviceImei  String
  method      String   // GPS, WIFI, IP, CELLULAR, MANUAL
  location    String
  accuracy    String?  // e.g. "High", "Medium", "Low"
  ipAddress   String?
  metadata    String?  // JSON - extra signal data
  loggedById  String?
  createdAt   DateTime @default(now())
}

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverRole String? // If null, it's a direct message to receiverId. "ALL" for global broadcast.
  receiverId  String?
  receiver    User?    @relation("ReceivedMessages", fields: [receiverId], references: [id])
  subject     String
  body        String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model MaintenanceRecord {
  id          String   @id @default(uuid())
  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  vendorId    String
  vendor      User     @relation("MaintenanceVendor", fields: [vendorId], references: [id])
  serviceType String?  // SCREEN_REPLACEMENT, BATTERY_CHANGE, SOFTWARE_UPDATE, MOTHERBOARD_REPAIR, GENERAL_CHECKUP, OTHER
  description String
  partsReplaced String?
  cost        Float?
  serviceDate DateTime @default(now())
  evidenceUrl String?
  createdAt   DateTime @default(now())
}
