<?xml version="1.0" encoding="utf-8"?>
<device-admin xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-policies>
        <limit-password />
        <watch-login />
        <reset-password />
        <force-lock />
        <wipe-data />
        <!-- 
        By demanding these high-level policies, we force Android to grant us 
        Device Admin status, which inherently locks the "Uninstall" button 
        in the settings menu, preventing a thief from casually deleting PTS.
        -->
    </uses-policies>
</device-admin>
